% layout 'default';
% title 'Submitting Drop Request';

<h1>Submitting Drop Request</h1>

<p>Please wait while your request is submitted.</p>

<form method="POST" action="<%= $action %>" id="auto-submit-form">
    <button type="submit">Submit</button>
</form>

<script>
document.getElementById('auto-submit-form').submit();
</script>
