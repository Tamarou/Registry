% my $event_url = url_for "workflow_callcc", target => 'event-creation';
<form action="<%= $action %>" method="POST">
    <input type="text" name="name" placeholder="Session Name" />
    <a rel="create-page event" href="<%= $event_url %>">Add Event</a>
    <input type="submit" value="Save" />
</form>
